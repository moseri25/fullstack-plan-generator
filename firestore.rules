rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: [auto-generated]
    // Fields:
    //   - userId: string (required) - The ID of the user who created the project
    //   - prompt: string (required, max 2000 chars) - The original prompt
    //   - title: string (required, max 200 chars) - The title of the project
    //   - createdAt: timestamp (required) - When the project was created
    //   - masterSkill: string (optional) - The master orchestrator skill
    //   - skills: list of objects (required, max 20 items) - The skills generated
    //     - id: string (required, max 100 chars)
    //     - title: string (required, max 100 chars)
    //     - content: string (required, max 50000 chars)
    //     - tags: list of strings (optional, max 10 items)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidSkill(skill) {
      return skill is map &&
             skill.keys().hasOnly(['id', 'title', 'content', 'tags']) &&
             skill.keys().hasAll(['id', 'title', 'content']) &&
             skill.id is string && skill.id.size() > 0 && skill.id.size() <= 100 &&
             skill.title is string && skill.title.size() > 0 && skill.title.size() <= 100 &&
             skill.content is string && skill.content.size() > 0 && skill.content.size() <= 50000 &&
             (!('tags' in skill) || (skill.tags is list && skill.tags.size() <= 10));
    }

    function areValidSkills(skillsList) {
      return skillsList is list && skillsList.size() <= 50 &&
             skillsList.all(skill, isValidSkill(skill));
    }

    function isValidProject() {
      return hasOnlyAllowedFields(['id', 'userId', 'prompt', 'title', 'createdAt', 'skills', 'audience', 'tone', 'numSkills', 'detailedPrompt', 'systemOptimization', 'skillChainOptimization', 'masterSkill']) &&
             hasRequiredFields(['userId', 'prompt', 'title', 'createdAt', 'skills']) &&
             validStringLength('userId', 1, 100) &&
             validStringLength('prompt', 1, 5000) &&
             validStringLength('title', 1, 500) &&
             (!('audience' in request.resource.data) || validStringLength('audience', 1, 200)) &&
             (!('tone' in request.resource.data) || validStringLength('tone', 1, 200)) &&
             (!('numSkills' in request.resource.data) || request.resource.data.numSkills is number) &&
             (!('detailedPrompt' in request.resource.data) || request.resource.data.detailedPrompt is string) &&
             (!('systemOptimization' in request.resource.data) || request.resource.data.systemOptimization is string) &&
             (!('skillChainOptimization' in request.resource.data) || request.resource.data.skillChainOptimization is string) &&
             (!('masterSkill' in request.resource.data) || request.resource.data.masterSkill is string) &&
             (request.resource.data.createdAt is timestamp || request.resource.data.createdAt == server.timestamp()) &&
             areValidSkills(request.resource.data.skills);
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                       isValidProject() && 
                       uidUnchanged();
      allow update: if isDocOwner() && 
                       isValidProject() && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}